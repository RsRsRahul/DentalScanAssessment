generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Scan {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending, completed, failed
  images    String   @default("") // Comma-separated list of image URLs (SQLite doesn't support scalar lists)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  scanId      String
  recipientId String
  type        String   @default("SCAN_COMPLETED")
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Thread {
  id        String    @id @default(cuid())
  scanId    String    @unique
  patientId String
  clinicId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id])
  senderId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
